// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supermarket {
  id        String         @id
  name      String
  logoUrl   String
  color     String         @default("#000000")
  prices    PriceHistory[]
}

model Product {
  id        Int            @id @default(autoincrement())
  name      String
  category  String
  imageUrl  String
  prices    PriceHistory[]
  userLists UserList[]     @relation("ListProducts")
}

model PriceHistory {
  id            Int         @id @default(autoincrement())
  price         Float
  date          DateTime    @default(now())
  
  productId     Int
  product       Product     @relation(fields: [productId], references: [id])
  
  supermarketId String
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])

  @@unique([productId, supermarketId, date])
}

model UserList {
  id          Int       @id @default(autoincrement())
  name        String
  userId      String    // Placeholder for Auth implementation
  products    Product[] @relation("ListProducts")
  createdAt   DateTime  @default(now())
}
