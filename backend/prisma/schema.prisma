// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Supermarket {
  id             String         @id
  name           String
  logo           String         @default("?")
  color          String         @default("#000000")
  priceHistories PriceHistory[]
  currentPrices  Price[]
  aliases        ProductAlias[]
}

model Product {
  id             Int            @id @default(autoincrement())
  ean            String?        @unique
  brand          String?
  weight         String?
  name           String
  category       String
  imageUrl       String         @map("image_url")
  priceHistories PriceHistory[]
  currentPrices  Price[]
  aliases        ProductAlias[]
  userLists      UserList[]     @relation("ListProducts")
}

model Price {
  id            Int         @id @default(autoincrement())
  price         Float
  updatedAt     DateTime    @default(now()) @map("updated_at")
  
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  
  supermarketId String      @map("supermarket_id")
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])

  @@unique([productId, supermarketId])
}

model PriceHistory {
  id            Int         @id @default(autoincrement())
  price         Float
  sourceUrl     String?     @map("source_url")
  date          DateTime    @default(now()) @map("recorded_at")
  
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  
  supermarketId String      @map("supermarket_id")
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])

  @@unique([productId, supermarketId, date])
}

model ProductAlias {
  id            Int         @id @default(autoincrement())
  originalName  String      @map("original_name")
  supermarketId String      @map("supermarket_id")
  supermarket   Supermarket @relation(fields: [supermarketId], references: [id])
  productId     Int         @map("product_id")
  product       Product     @relation(fields: [productId], references: [id])
  createdAt     DateTime    @default(now()) @map("created_at")

  @@unique([supermarketId, originalName])
}

model UserList {
  id          Int       @id @default(autoincrement())
  name        String
  userId      String    @map("user_id")
  products    Product[] @relation("ListProducts")
  createdAt   DateTime  @default(now()) @map("created_at")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
}

model ScraperLog {
  id           Int      @id @default(autoincrement())
  provider     String
  status       String   // OK, WARNING, FAILED
  itemsScraped Int      @default(0) @map("items_scraped")
  errors       Int      @default(0)
  errorMessage String?  @map("error_message")
  startedAt    DateTime @map("started_at")
  finishedAt   DateTime @default(now()) @map("finished_at")
}
