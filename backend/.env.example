PORT=3001
NODE_ENV=development

# PostgreSQL connection string (Neon, local Docker, etc.)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/ahorrotuc_db?schema=public"

# Redis URL for horizontal scaling (optional, fallback to in-memory cache)
# Format: redis://[:PASSWORD@]HOST:PORT[/DB]
# Example (local Docker): redis://localhost:6379
# Example (Upstash): rediss://default:PASSWORD@HOST:PORT
REDIS_URL=""

# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:5173

# Set to "true" to skip automatic database seeding on startup
SKIP_SEED=false
